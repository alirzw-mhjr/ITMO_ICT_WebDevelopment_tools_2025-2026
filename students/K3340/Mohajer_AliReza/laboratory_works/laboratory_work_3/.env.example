# Пример переменных окружения. Значения по умолчанию уже заданы в
# docker-compose.yml, поэтому отдельный .env для запуска не обязателен.

# База данных — файл SQLite из ЛР 1 (примонтирован в контейнеры как /lab1).
DATABASE_URL=sqlite:////lab1/app.db
REDIS_URL=redis://redis:6379/0
PARSER_URL=http://parser:8001
